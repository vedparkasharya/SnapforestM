# ============================================
# SnapforestX Environment Variables
# ============================================
# For PRODUCTION (Vercel), set these in Vercel Dashboard > Settings > Environment Variables
# NEVER commit .env.local to GitHub - it is already in .gitignore
# ============================================

# --- MongoDB (REQUIRED) ---
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/snapforestx?retryWrites=true&w=majority

# --- Razorpay Payments (REQUIRED for real payments) ---
# Step 1: Get your LIVE keys from https://dashboard.razorpay.com/app/keys
# Step 2: Set RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET in Vercel dashboard
# Step 3: The frontend now gets the key from the API response - NO need for NEXT_PUBLIC_RAZORPAY_KEY_ID
#
# NOTE: We no longer use NEXT_PUBLIC_RAZORPAY_KEY_ID.
# The Razorpay key is now securely returned from the backend API (/api/bookings).
# Just set the server-side keys below and the frontend will automatically work.
RAZORPAY_KEY_ID=rzp_live_your_live_key_here
RAZORPAY_KEY_SECRET=your_live_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# --- Cloudinary (OPTIONAL - for image uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# --- SMTP Email (OPTIONAL - for booking confirmations) ---
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# --- App URL ---
NEXT_PUBLIC_APP_URL=https://snapforest-m.vercel.app
