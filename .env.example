# ============================================================
# SnapforestX - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git!
# ============================================================

# ---------------------------------------------------------------
# NextAuth Configuration (REQUIRED for authentication)
# ---------------------------------------------------------------
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_super_secret_random_string_here

# NextAuth URL - Set to your production domain
NEXTAUTH_URL=https://snapforest-m.vercel.app

# ---------------------------------------------------------------
# Google OAuth (REQUIRED for Google Sign-In)
# Get from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
# ---------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ---------------------------------------------------------------
# MongoDB (REQUIRED for database)
# Get free tier from: https://www.mongodb.com/atlas/database
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# ---------------------------------------------------------------
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/snapforest

# ---------------------------------------------------------------
# Razorpay (REQUIRED for payments)
# Get test keys from: https://dashboard.razorpay.com/app/keys
# ---------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Public Razorpay key (used in frontend)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ---------------------------------------------------------------
# Cloudinary (OPTIONAL - for image uploads)
# Get from: https://cloudinary.com/users/register/free
# ---------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---------------------------------------------------------------
# Email/SMTP (OPTIONAL - for booking confirmations)
# Use Gmail App Password: https://myaccount.google.com/apppasswords
# ---------------------------------------------------------------
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ---------------------------------------------------------------
# Admin Email (optional - defaults to vedprakasharya9973@gmail.com)
ADMIN_EMAIL=vedprakasharya9973@gmail.com

# ---------------------------------------------------------------
# Debug Mode (optional - enables NextAuth debug logs)
# Set to "true" to see detailed auth logs in Vercel
NEXTAUTH_DEBUG=false
