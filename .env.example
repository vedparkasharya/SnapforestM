# ============================================================
# SnapforestX - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git!
# ============================================================

# ------------------------------------------------------------
# MongoDB (REQUIRED for database)
# Get free tier from: https://www.mongodb.com/atlas/database
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# ------------------------------------------------------------
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/snapforest

# ------------------------------------------------------------
# Razorpay (REQUIRED for real payments)
# Get FREE test keys from: https://dashboard.razorpay.com/app/keys
# 
# DEMO MODE: If you skip these, bookings still work in demo mode
# without real payments. Add keys when you're ready to go live.
# 
# How to get test keys (FREE):
# 1. Sign up at https://dashboard.razorpay.com/signup
# 2. Switch to "Test Mode" (toggle in top-right)
# 3. Go to Settings → API Keys → Generate Test Key
# 4. Copy Key ID and Key Secret here
# ------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Public Razorpay key (used in frontend - same as RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# ------------------------------------------------------------
# Cloudinary (OPTIONAL - for image uploads)
# Get from: https://cloudinary.com/users/register/free
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ------------------------------------------------------------
# Email/SMTP (OPTIONAL - for booking confirmations)
# Use Gmail App Password: https://myaccount.google.com/apppasswords
# ------------------------------------------------------------
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ------------------------------------------------------------
# Admin Email (optional - defaults to vedprakasharya9973@gmail.com)
ADMIN_EMAIL=vedprakasharya9973@gmail.com

# ------------------------------------------------------------
# App URL
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://snapforest-m.vercel.app
